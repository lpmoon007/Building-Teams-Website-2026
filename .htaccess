RewriteRule ^(blog/)?novartiss-recreation-event-supports-indian-summer-camp/?$ /case-studies/ [R=301,NC,L]
RewriteRule ^(blog/)?14-actelion-employees-built-a-better-tomorrow/?$ /case-studies/ [R=301,NC,L]
RewriteRule ^(blog/)?sole-purpose-in-new-jersey/?$ /case-studies/ [R=301,NC,L]
RewriteRule ^(blog/)?california-pizza-kitchen-inspires-action-on-sailing-adventure/?$ /case-studies/ [R=301,NC,L]
RewriteRule ^(blog/)?enel-green-power-walks-on-fire/?$ /case-studies/ [R=301,NC,L]
RewriteRule ^(blog/)?a-to-z-media-goes-beyond-traditional-team-building/?$ /case-studies/ [R=301,NC,L]
# Everything else under /blog/ (unrevived posts, feeds, dated permalinks) -> Resources
RewriteRule ^blog(/|$) /resources/ [R=301,NC,L]

# ----- end redirect map -----
