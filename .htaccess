# Leadership activity article -> existing leadership exercises guide
RewriteRule ^leadership_activity_ideas\.htm/?$ /resources/team-building-ideas/leadership-team-building-exercises/ [R=301,NC,L]
# Rest of the old executive microsite -> executive team building
RewriteRule ^Executive_Teambuilding/ /executive-team-building/ [R=301,NC,L]
RewriteRule ^i/best-seller\.png/?$ / [R=301,NC,L]
RewriteRule ^wp-content/uploads/2019/08/Learning-maze\.jpg/?$ / [R=301,NC,L]
RewriteRule ^teambuilding_workshops/youth_education/education_teambuilding_workshops\.htm/?$ /team-building-workshops/ [R=301,NC,L]
RewriteRule ^Adventure_Teambuilding/corporate_sailing(_shackletons_adventure)?\.htm/?$ /experiences/corporate-sailing/ [R=301,NC,L]
