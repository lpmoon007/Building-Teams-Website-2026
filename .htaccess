RewriteRule (^|/)corporate_orienteering\.htm/?$ /experiences/team-orienteering/ [R=301,NC,L]
RewriteRule ^workshops/two-hour-team-building-workshops/what-is-wrong-with-you/?$ /resources/ [R=301,NC,L]
