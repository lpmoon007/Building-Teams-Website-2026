# Workshop URL families -> the dedicated team building workshops page
# (NOTE: no rule for ^team-building-workshops — that is now a real page)
RewriteRule ^teambuilding_workshops(/|$) /team-building-workshops/ [R=301,NC,L]
RewriteRule ^workshops(/|$) /team-building-workshops/ [R=301,NC,L]

# ----- Old WordPress blog: 7 revived evergreen posts -> new articles, rest -> Resources -----
RewriteRule ^(blog/)?untangling-complex-group-dynamics/?$ /resources/untangling-group-dynamics/ [R=301,NC,L]
RewriteRule ^(blog/)?the-five-cs-of-managing-virtual-teams/?$ /resources/managing-virtual-teams/ [R=301,NC,L]
RewriteRule ^(blog/)?accountability-starts-with-you-excuse-me/?$ /resources/accountability-starts-with-me/ [R=301,NC,L]
RewriteRule ^(blog/)?why-teams-and-team-building/?$ /resources/why-team-building/ [R=301,NC,L]
RewriteRule ^(blog/)?myers-briggs-mbti-as-a-team-building-tool/?$ /resources/myers-briggs-team-building/ [R=301,NC,L]
RewriteRule ^(blog/)?5-ways-to-ensure-your-teambuilding-will-suck/?$ /resources/why-team-building-fails/ [R=301,NC,L]
RewriteRule ^(blog/)?we-see-what-we-look-for/?$ /resources/we-see-what-we-look-for/ [R=301,NC,L]
# Client event recaps -> Case Studies (folded in as "in the field" proof)
RewriteRule ^(blog/)?devry-builds-108-bicycles-and-108-dreams/?$ /case-studies/ [R=301,NC,L]
RewriteRule ^(blog/)?60-children-get-brand-new-bicycles-at-nbcuniversal-conference/?$ /case-studies/ [R=301,NC,L]
