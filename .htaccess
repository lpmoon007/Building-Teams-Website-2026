# ============================================================
# Building Teams — redirect map  (301 preserve + 410 spam removal)
# Generated from Semrush backlink analysis. Place at the site root.
# Implements "Redirect Map (from backlinks).csv".
# NOTE: the homepage "/" is intentionally NOT redirected (it KEEPS its 781 backlinks).
# ============================================================

Options +FollowSymLinks
RewriteEngine On

# ----- Canonical host + HTTPS (matches https://www. canonicals) -----
# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://www.buildingteams.com%{REQUEST_URI} [R=301,L]
# Force www
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ----- HSTS (site is HTTPS-only; conservative 1yr, no includeSubDomains/preload) -----
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000"
</IfModule>

# Serve folder index + clean directory URLs
DirectoryIndex index.html

# Custom error page
ErrorDocument 404 /404.html

# ----- 410 GONE: spam-injected pages (kill, do NOT redirect) -----
# Every /news/* URL on the old site was injected casino/essay/pharma spam.
RewriteRule ^news/ - [G,NC,L]
RewriteRule ^zajm-onlajn-absoljutno-vsem-na-kartu/?$ - [G,NC,L]
RewriteRule ^top-resume-service-2/?$ - [G,NC,L]
RewriteRule ^kak-vzjat-kredit-bez-kreditnoj-istorii/?$ - [G,NC,L]
RewriteRule ^home-inspection-checklists/?$ - [G,NC,L]
RewriteRule ^pdf-accounting-basics-for-beginners-accounting/?$ - [G,NC,L]
RewriteRule ^banking-option-of-the-wolf-winner-casino-online-for-dummies/?$ - [G,NC,L]
RewriteRule ^naklejka-viza-masterkard-pay-pass-visa-paywave/?$ - [G,NC,L]
RewriteRule ^pjat-prichin-pochemu-bank-otkazhet-v-kredite/?$ - [G,NC,L]
RewriteRule ^(gambling-online|online-gambling)/?$ - [G,NC,L]

# ----- Backlink recovery: specific legacy URLs with real editorial links -----
# MUST precede the broad catch-alls below (first match with [L] wins), so these
# land on their MOST specific modern page instead of the generic library.
RewriteRule ^Teambuilding_Activity/communication_exercises\.htm/?$ /resources/communication-team-building-activities/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/trust_teambuilding_exercises\.htm/?$ /resources/team-building-activities/trust-walk/ [R=301,NC,L]
RewriteRule ^teambuilding_articles/teamexperience\.htm/?$ /resources/experiential-learning/ [R=301,NC,L]
RewriteRule ^teambuilding_activity/all_teambuilding_exercises\.htm/?$ /resources/team-building-activities/ [R=301,NC,L]
RewriteRule ^blog/2011/06/22/innovation-the-candle-puzzle/?$ /resources/what-motivates-teams/ [R=301,NC,L]

# ----- Ranking preservation: legacy URLs holding organic positions -----
# These currently 404 or fall to a too-generic catch-all; route each to the
# closest modern page so its Google ranking transfers instead of dropping.
# (MUST precede the broad ^product/, ^Teambuilding_Activity/, ^workshops rules.)
RewriteRule ^Leadership/legendary_leadership\.htm/?$ /executive-team-building/ [R=301,NC,L]
RewriteRule ^Leadership(/|$) /executive-team-building/ [R=301,NC,L]
RewriteRule ^Building_Corporate_Teams(/|$) / [R=301,NC,L]
RewriteRule ^adventure-team-building/sailing-as-team-building/?$ /experiences/corporate-sailing/ [R=301,NC,L]
RewriteRule ^adventure-team-building(/|$) /experiences/ [R=301,NC,L]
RewriteRule ^team-building-workshops/all-team-building-workshops/?$ /team-building-workshops/ [R=301,NC,L]
RewriteRule ^workshops/facilitator-training-course/?$ /effective-facilitation-workshop/ [R=301,NC,L]
RewriteRule ^executive-team-building/leadership-development/?$ /executive-team-building/ [R=301,NC,L]
# "team building kits" ranks via several old kit/product pages -> consolidate on the kits page
RewriteRule ^team-building-activity-kits/?$ /team-building-kits/ [R=301,NC,L]
RewriteRule ^product/limited-materials-digital-kit/?$ /team-building-kits/ [R=301,NC,L]
RewriteRule ^product/communication-team-building-kit/?$ /team-building-kits/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Kits(/|$) /team-building-kits/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Simulations/index\.html?/?$ /team-building-kits/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/best_selling_team_products\.htm/?$ /team-building-kits/ [R=301,NC,L]
# Problem-solving exercises -> the specific guide (not the generic library)
RewriteRule ^Teambuilding_Activity/problem_solving_exercises\.htm/?$ /resources/problem-solving-team-building-activities/ [R=301,NC,L]

# ----- Activity library consolidation: old DIY activity / kit / exercise tree -----
# The Scavenger Hunt maps to its dedicated rebuild; everything else in the
# /Teambuilding_Activity/ tree (individual games, kits, exercises-by-outcome,
# simulations) consolidates into the new activities library so it inherits the
# link equity these high-ranking pages earned. [NC] also catches lowercase paths.
RewriteRule ^Teambuilding_Activity/Simulations/scavenger_hunt\.htm/?$ /experiences/the-ultimate-hunt/ [R=301,NC,L]
# Individual activity pages now exist -> route each old game URL to its exact new page (link equity)
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/alphabet_soup\.html?/?$ /resources/team-building-activities/alphabet-soup/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/ball_mania\.html?/?$ /resources/team-building-activities/ball-mania/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/bull_ring\.html?/?$ /resources/team-building-activities/bull-ring/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/chain_of_command\.html?/?$ /resources/team-building-activities/chain-of-command/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/change_five\.html?/?$ /resources/team-building-activities/change-five/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/china_syndrome\.html?/?$ /resources/team-building-activities/china-syndrome/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/dont_touch_me\.html?/?$ /resources/team-building-activities/dont-touch-me/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/get_it_together\.html?/?$ /resources/team-building-activities/get-it-together/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/group_juggling\.html?/?$ /resources/team-building-activities/group-juggling/ [R=301,NC,L]
# Highwire discontinued (unsafe) -> route old game URL and the retired clean URL to the library
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/highwire\.html?/?$ /resources/team-building-activities/ [R=301,NC,L]
RewriteRule ^resources/team-building-activities/highwire/?$ /resources/team-building-activities/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/knot_a_team\.html?/?$ /resources/team-building-activities/knot-a-team/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/knot_or_not_a_knot\.html?/?$ /resources/team-building-activities/knot-or-not-a-knot/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/learning_maze\.html?/?$ /resources/team-building-activities/learning-maze/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/let_go_my_ego\.html?/?$ /resources/team-building-activities/let-go-my-ego/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/magic_carpet\.html?/?$ /resources/team-building-activities/magic-carpet/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/orange_ball_race\.html?/?$ /resources/team-building-activities/orange-ball-race/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/perfect_square\.html?/?$ /resources/team-building-activities/perfect-square/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/river_crossing\.html?/?$ /resources/team-building-activities/river-crossing/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/search_and_rescue\.html?/?$ /resources/team-building-activities/search-and-rescue/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/supply_chain\.html?/?$ /resources/team-building-activities/supply-chain/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/team_shackles\.html?/?$ /resources/team-building-activities/team-shackles/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/tied_in_knots\.html?/?$ /resources/team-building-activities/tied-in-knots/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/trust_walk\.html?/?$ /resources/team-building-activities/trust-walk/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/washing_machines\.html?/?$ /resources/team-building-activities/washing-machines/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/who_are_you\.html?/?$ /resources/team-building-activities/who-are-you/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/Teambuilding_Games/win_win_win\.html?/?$ /resources/team-building-activities/win-win-win/ [R=301,NC,L]
RewriteRule ^Teambuilding_Activity/ /resources/team-building-activities/ [R=301,NC,L]
# WordPress-era product URLs for individual activities -> activity library
RewriteRule ^product/win-win-win/?$ /resources/team-building-activities/win-win-win/ [R=301,NC,L]
RewriteRule ^product/perfect-square/?$ /resources/team-building-activities/perfect-square/ [R=301,NC,L]
RewriteRule ^product/bull-ring-team-building-activity/?$ /resources/team-building-activities/bull-ring/ [R=301,NC,L]
RewriteRule ^product/ /resources/team-building-activities/ [R=301,NC,L]

# ----- 301 MOVED PERMANENTLY: legit old pages -> new URLs -----
RewriteRule ^teambuilding_faqs\.htm/?$ /faq/ [R=301,NC,L]
RewriteRule ^teambuilding_tools\.htm/?$ /resources/team-building-activities/ [R=301,NC,L]
RewriteRule ^teambuilding_teachers\.htm/?$ /resources/ [R=301,NC,L]
RewriteRule ^teambuilding_links\.htm/?$ /resources/ [R=301,NC,L]
RewriteRule ^team_building_spy_scenarios\.htm/?$ /resources/team-building-spy-scenarios/ [R=301,NC,L]
# Old articles hub + individual article pages -> Resources
RewriteRule ^teambuilding_articles\.htm/?$ /resources/ [R=301,NC,L]
RewriteRule ^Teambuilding_Articles/ /resources/ [R=301,NC,L]
# Staff-retreat keyword cluster -> corporate retreat ideas
RewriteRule ^staff_retreat_games_ideas\.htm/?$ /resources/corporate-retreat-ideas/ [R=301,NC,L]
RewriteRule ^staff_retreat_teambuilding_non_profit_organization\.htm/?$ /resources/corporate-retreat-ideas/ [R=301,NC,L]
# Old team building books product page -> activities library
RewriteRule (^|/)teambuildingbooks\.htm/?$ /resources/team-building-activities/ [R=301,NC,L]

# Old email newsletters (/newsletters/*) -> best-match modern pages
RewriteRule ^newsletters/motivation\.html?/?$ /resources/what-motivates-teams/ [R=301,NC,L]
RewriteRule ^newsletters/valentines_day\.html?/?$ /resources/team-building-activities/ [R=301,NC,L]
RewriteRule ^newsletters/10_step_process\.html?/?$ /resources/ [R=301,NC,L]

# Old Repario /team/ microsite -> best-match modern pages, rest to Resources
RewriteRule ^team/team_building_blueprint_excellence/ /programs/blueprint-for-excellence/ [R=301,NC,L]
RewriteRule ^team/team_building_event/[a-z_]*building_a_dream[a-z_]*\.htm/?$ /activities/bike-build/ [R=301,NC,L]
RewriteRule ^team/team_building_event/[a-z_]*scavanger[a-z_]*\.htm/?$ /experiences/the-ultimate-hunt/ [R=301,NC,L]
RewriteRule ^team/ /resources/ [R=301,NC,L]

# Old Conference_Teambuilding + Executive_Teambuilding trees -> modern pages
RewriteRule ^Executive_Teambuilding/executive_teambuilding_succc?ess_stories\.htm/?$ /executive-team-building/success-stories/ [R=301,NC,L]
RewriteRule ^Conference_Teambuilding/conference_teambuilding\.htm/?$ /conference-team-building/ [R=301,NC,L]
